# AIRS FEATURE-013 Real Data Integration environment template.
# Do not commit real secrets. Copy to .env locally and fill only the values you need.
# 免责声明：AIRS 仅用于投资研究流程编排和质量控制，不构成投资建议。

# mock is the default and never touches the network. Set real globally or per connector.
AIRS_CONNECTOR_MODE=mock
# AIRS_SEC_EDGAR_MODE=real
# AIRS_RSS_MODE=real
# AIRS_GITHUB_MODE=real
# AIRS_NEWS_MODE=real

AIRS_HTTP_TIMEOUT_SECONDS=8
AIRS_RATE_LIMIT_SECONDS=0.1
AIRS_HTTP_USER_AGENT=AIRS Real Data Integration/0.1 contact=your-email@example.com

# Optional: raises GitHub API rate limits.
GITHUB_TOKEN=

# Optional: generic news endpoint. The endpoint should return JSON.
NEWS_API_ENDPOINT=
NEWS_API_KEY=
NEWS_API_KEY_NAME=apiKey

# RELEASE-001 Platform Productization
AIRS_CONFIG=config/airs.yaml
AIRS_API_HOST=0.0.0.0
AIRS_API_PORT=8765
AIRS_WEB_HOST=0.0.0.0
AIRS_WEB_PORT=8080
AIRS_WEB_API_BASE_URL=http://localhost:8765
AIRS_WORKSPACE_DIR=./workspace-data
AIRS_CACHE_DIR=./.cache/airs
AIRS_DEMO_MODE=true
AIRS_REQUIRE_DISCLAIMER=true
