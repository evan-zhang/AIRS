{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "version": "0.1.0",
  "disclaimer": "本 Schema 仅用于 AIRS 工程开发与研究质量控制，不构成投资建议，不提供荐股、自动交易、交易指令、目标价或收益承诺。",
  "title": "AIRS Connector Result Schema",
  "type": "object",
  "required": [
    "connector_id",
    "source",
    "source_type",
    "url",
    "timestamp",
    "version",
    "trace_id",
    "data",
    "traceability",
    "disclaimer"
  ],
  "properties": {
    "connector_id": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "source_type": {
      "type": "string"
    },
    "url": {
      "type": "string"
    },
    "timestamp": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "trace_id": {
      "type": "string"
    },
    "data": {
      "type": "object"
    },
    "traceability": {
      "type": "object",
      "required": [
        "connector",
        "request_id",
        "cache_hit",
        "transformations"
      ],
      "properties": {
        "connector": {
          "type": "string"
        },
        "request_id": {
          "type": "string"
        },
        "cache_hit": {
          "type": "boolean"
        },
        "transformations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "error": {
      "type": "object"
    },
    "disclaimer": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
