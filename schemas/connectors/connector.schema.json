{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "version": "0.1.0",
  "trace_id_note": "Connector Result 必须包含 trace_id、timestamp 和 traceability。",
  "disclaimer": "本 Schema 仅用于 AIRS 工程开发与研究质量控制，不构成投资建议，不提供荐股、自动交易、交易指令、目标价或收益承诺。",
  "title": "AIRS Connector Schema",
  "type": "object",
  "required": [
    "connector_id",
    "name",
    "source",
    "source_type",
    "base_url",
    "version",
    "config",
    "input_schema",
    "output_schema",
    "retry_policy",
    "cache_strategy",
    "health_check",
    "test_case",
    "disclaimer"
  ],
  "properties": {
    "connector_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "source_type": {
      "enum": [
        "official",
        "regulatory",
        "company",
        "exchange",
        "trusted_third_party",
        "public_news",
        "community"
      ]
    },
    "base_url": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "config": {
      "type": "object"
    },
    "input_schema": {
      "type": "object"
    },
    "output_schema": {
      "type": "object"
    },
    "error_handling": {
      "type": "object"
    },
    "retry_policy": {
      "type": "object"
    },
    "cache_strategy": {
      "type": "object"
    },
    "health_check": {
      "type": "object"
    },
    "test_case": {
      "type": "object"
    },
    "disclaimer": {
      "type": "string",
      "const": "不构成投资建议"
    }
  },
  "additionalProperties": true
}
