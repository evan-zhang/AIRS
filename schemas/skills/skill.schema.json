{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://airs.local/schemas/skills/skill.schema.json",
  "title": "AIRS Skill Schema",
  "description": "AIRS M5 Skill Engine 的单个 Skill 结构 Schema。用于验证 Skill 元数据、依赖引用、输入输出契约、工作流、失败处理和审查清单。该 Schema 只服务投资研究流程质量控制，不构成投资建议。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "skill_id",
    "name",
    "version",
    "status",
    "purpose",
    "inputs",
    "outputs",
    "dependencies",
    "invoked_prompt",
    "invoked_methodology",
    "invoked_evidence",
    "workflow",
    "failure_handling",
    "review_checklist",
    "disclaimer"
  ],
  "properties": {
    "skill_id": {
      "type": "string",
      "pattern": "^airs\\.skill\\.[a-z0-9-]+\\.v[0-9]+$"
    },
    "name": {
      "type": "string",
      "minLength": 2
    },
    "version": {
      "type": "string",
      "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "status": {
      "type": "string",
      "enum": ["Draft", "Review", "Active", "Deprecated", "Archived", "Rejected"]
    },
    "purpose": {
      "type": "string",
      "minLength": 20
    },
    "inputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/io_field"
      }
    },
    "outputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/io_field"
      }
    },
    "dependencies": {
      "type": "object",
      "required": ["prompts", "methodologies", "evidence_components"],
      "additionalProperties": false,
      "properties": {
        "prompts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^prompts/.+\\.md$"
          }
        },
        "methodologies": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^docs/methodology/.+\\.md$"
          }
        },
        "evidence_components": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^(docs/evidence/.+\\.md|schemas/evidence/.+\\.schema\\.json)$"
          }
        }
      }
    },
    "invoked_prompt": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "invoked_methodology": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "invoked_evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "workflow": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "string",
        "minLength": 10
      }
    },
    "failure_handling": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 10
      }
    },
    "review_checklist": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "string",
        "minLength": 8
      }
    },
    "disclaimer": {
      "type": "string",
      "const": "仅供研究参考，不构成投资建议。投资有风险，决策需谨慎。"
    }
  },
  "$defs": {
    "io_field": {
      "type": "object",
      "required": ["name", "type", "required", "description"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "required": {
          "type": "boolean"
        },
        "description": {
          "type": "string",
          "minLength": 5
        }
      }
    }
  }
}

