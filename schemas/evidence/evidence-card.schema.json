{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://airs.local/schemas/evidence/evidence-card.schema.json",
  "title": "AIRS Evidence Card Schema",
  "description": "定义 AIRS Evidence Engine 的最小证据单元。所有投资研究证据卡必须包含来源、等级、支持命题、反证、缺口、权重、追溯和版本信息。本 Schema 仅用于研究质量控制，不构成投资建议。",
  "type": "object",
  "required": [
    "evidence_id",
    "title",
    "category",
    "source",
    "source_type",
    "url",
    "publication_time",
    "collection_time",
    "confidence",
    "evidence_level",
    "supports",
    "refutes",
    "missing_evidence",
    "weight",
    "traceability",
    "version"
  ],
  "additionalProperties": false,
  "properties": {
    "evidence_id": {
      "type": "string",
      "pattern": "^EV-[0-9]{8}-[A-Z0-9]{4,}$",
      "description": "Evidence ID，全局唯一证据编号，建议格式 EV-YYYYMMDD-XXXX。"
    },
    "title": {
      "type": "string",
      "minLength": 4,
      "description": "Title，证据卡标题。"
    },
    "category": {
      "type": "string",
      "enum": [
        "financial",
        "supply_chain",
        "industry",
        "policy",
        "management",
        "valuation",
        "risk",
        "market",
        "counter_evidence",
        "background",
        "other"
      ],
      "description": "Category，证据类别。"
    },
    "source": {
      "type": "string",
      "minLength": 2,
      "description": "Source，来源名称。"
    },
    "source_type": {
      "type": "string",
      "enum": [
        "company_filing",
        "regulatory_filing",
        "government_policy",
        "official_statistics",
        "industry_report",
        "broker_research",
        "news",
        "expert_opinion",
        "database",
        "internal_note",
        "other"
      ],
      "description": "Source Type，来源类型。"
    },
    "url": {
      "type": "string",
      "minLength": 1,
      "description": "URL，公开链接、内部文档路径或 unavailable_reason。"
    },
    "publication_time": {
      "type": "string",
      "format": "date-time",
      "description": "Publication Time，来源发布时间。"
    },
    "collection_time": {
      "type": "string",
      "format": "date-time",
      "description": "Collection Time，证据采集时间。"
    },
    "confidence": {
      "oneOf": [
        {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        {
          "type": "string",
          "enum": ["LOW", "MEDIUM", "HIGH"]
        }
      ],
      "description": "Confidence，证据在当前命题下的可信度。"
    },
    "evidence_level": {
      "type": "string",
      "enum": ["A", "B", "C", "D", "E"],
      "description": "Evidence Level，证据等级。"
    },
    "supports": {
      "type": "array",
      "minItems": 1,
      "description": "Supports，证据支持的命题。",
      "items": {
        "$ref": "#/$defs/claimRelation"
      }
    },
    "refutes": {
      "type": "array",
      "description": "Refutes，证据反驳或削弱的命题；无直接反驳时也应记录已检查范围。",
      "items": {
        "$ref": "#/$defs/claimRelation"
      }
    },
    "missing_evidence": {
      "type": "array",
      "minItems": 1,
      "description": "Missing Evidence，仍缺少的关键证据或未发现缺口的检查说明。",
      "items": {
        "type": "string",
        "minLength": 4
      }
    },
    "weight": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Weight，证据在当前证据链中的研究权重，不代表投资评级。"
    },
    "traceability": {
      "type": "object",
      "required": ["collected_by", "collection_method", "source_locator", "transformations"],
      "additionalProperties": false,
      "description": "Traceability，证据采集、处理、审查和引用追踪。",
      "properties": {
        "collected_by": {
          "type": "string",
          "minLength": 2
        },
        "reviewed_by": {
          "type": "string"
        },
        "collection_method": {
          "type": "string",
          "minLength": 2
        },
        "source_locator": {
          "type": "string",
          "minLength": 1
        },
        "transformations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "downstream_references": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Version，证据卡语义化版本。"
    },
    "summary": {
      "type": "string",
      "description": "证据摘要。"
    },
    "review_status": {
      "type": "string",
      "enum": [
        "DRAFT",
        "IN_REVIEW",
        "APPROVED",
        "APPROVED_WITH_LIMITATION",
        "NEEDS_UPDATE",
        "DEPRECATED",
        "REJECTED"
      ]
    }
  },
  "$defs": {
    "claimRelation": {
      "type": "object",
      "required": ["claim_id", "statement", "strength"],
      "additionalProperties": false,
      "properties": {
        "claim_id": {
          "type": "string",
          "minLength": 2
        },
        "statement": {
          "type": "string",
          "minLength": 8
        },
        "strength": {
          "type": "string",
          "enum": ["strong", "medium", "weak"]
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
