{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://airs.local/schemas/investment/investment-thesis.schema.json",
  "title": "AIRS Investment Thesis",
  "description": "Structured thesis generated by Investment Research Engine. 不构成投资建议。",
  "type": "object",
  "required": ["thesis_id", "topic", "core_thesis", "statements", "methodology_refs", "disclaimer"],
  "properties": {
    "thesis_id": {"type": "string"},
    "topic": {"type": "string"},
    "core_thesis": {"type": "string"},
    "statements": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "object",
        "required": ["statement_id", "statement_type", "text", "confidence"],
        "properties": {
          "statement_id": {"type": "string"},
          "statement_type": {"type": "string", "enum": ["Fact", "Inference", "Assumption", "Opinion"]},
          "text": {"type": "string"},
          "evidence_refs": {"type": "array", "items": {"type": "string"}},
          "confidence": {"type": "number", "minimum": 0, "maximum": 1},
          "rationale": {"type": "string"}
        }
      }
    },
    "methodology_refs": {"type": "array", "items": {"type": "string"}},
    "disclaimer": {
      "type": "string",
      "description": "必须声明不构成投资建议。"
    }
  },
  "additionalProperties": true
}
