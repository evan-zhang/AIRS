{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://airs.local/schemas/benchmark/benchmark.schema.json",
  "title": "AIRS Benchmark Schema",
  "description": "AIRS Benchmark 结构 Schema，用于描述研究基准用例。仅用于研究质量控制，不构成投资建议。",
  "type": "object",
  "required": [
    "benchmark_id",
    "title",
    "version",
    "category",
    "methodology_refs",
    "prompt_refs",
    "evidence_requirements",
    "gold_standard",
    "evaluation_criteria",
    "expected_output",
    "failure_cases",
    "disclaimer"
  ],
  "properties": {
    "benchmark_id": {"type": "string", "pattern": "^BENCH-[A-Z0-9_-]+$"},
    "title": {"type": "string", "minLength": 4},
    "version": {"type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$"},
    "category": {"type": "string", "enum": ["ai", "semiconductor", "innovative-drug", "robotics", "new-energy", "general"]},
    "difficulty": {"type": "string", "enum": ["EASY", "MEDIUM", "HARD"]},
    "methodology_refs": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "prompt_refs": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "evidence_requirements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["evidence_level", "confidence", "weight", "supports", "refutes", "missing_evidence"],
        "properties": {
          "evidence_level": {"type": "string", "enum": ["A", "B", "C", "D", "E"]},
          "confidence": {"type": "string", "enum": ["LOW", "MEDIUM", "HIGH"]},
          "weight": {"type": "number", "minimum": 0, "maximum": 1},
          "supports": {"type": "array", "items": {"type": "string"}, "minItems": 1},
          "refutes": {"type": "array", "items": {"type": "string"}},
          "missing_evidence": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "gold_standard": {"type": "string", "minLength": 50},
    "evaluation_criteria": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "expected_output": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "failure_cases": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "quality_gate": {"type": "string", "enum": ["PASS", "CONDITIONAL_PASS", "FAIL"]},
    "disclaimer": {"type": "string", "const": "仅供研究参考，不构成投资建议"}
  },
  "additionalProperties": false
}
