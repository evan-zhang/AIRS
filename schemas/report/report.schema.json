{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://airs.local/schemas/report/report.schema.json",
  "title": "AIRS Research Report Schema",
  "description": "定义 AIRS Research Report Generator 的结构化报告 artifact。报告仅用于研究质量控制，不构成投资建议。",
  "type": "object",
  "required": [
    "report_id",
    "title",
    "research_question",
    "methodology_refs",
    "evidence_cards",
    "knowledge_graph_summary",
    "score_summary",
    "sections",
    "source_refs",
    "disclaimer",
    "version"
  ],
  "additionalProperties": false,
  "properties": {
    "report_id": {
      "type": "string",
      "pattern": "^REPORT-[0-9]{8}-[A-Z0-9-]+$"
    },
    "title": {
      "type": "string",
      "minLength": 4
    },
    "research_question": {
      "type": "string",
      "minLength": 8
    },
    "methodology_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" },
      "description": "M2 Methodology Layer 引用。"
    },
    "evidence_cards": {
      "type": "object",
      "minProperties": 2,
      "description": "M3 Evidence Engine 输出的 Evidence Card 字典。"
    },
    "knowledge_graph_summary": {
      "type": "object",
      "required": ["graph_id", "node_count", "edge_count", "path_count", "top_chokepoint", "evidence_refs"],
      "description": "FEATURE-002 Knowledge Graph Engine 汇总。"
    },
    "score_summary": {
      "type": "object",
      "required": ["scorecard_id", "overall_score", "overall_grade", "confidence_score", "quality_gate", "evidence_chain_refs"],
      "description": "M6 Score/Evaluation Engine 汇总。"
    },
    "sections": {
      "type": "array",
      "minItems": 12,
      "items": {
        "type": "object",
        "required": ["section_id", "title", "body", "evidence_refs", "kg_refs", "score_refs"],
        "additionalProperties": false,
        "properties": {
          "section_id": { "type": "string" },
          "title": { "type": "string" },
          "body": { "type": "string", "minLength": 8 },
          "evidence_refs": { "type": "array", "items": { "type": "string" } },
          "kg_refs": { "type": "array", "items": { "type": "string" } },
          "score_refs": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "source_refs": {
      "type": "object",
      "required": [
        "M2_methodology",
        "M3_evidence",
        "FEATURE_002_knowledge_graph",
        "M4_prompt",
        "M5_skill",
        "M6_score_eval"
      ],
      "description": "报告对 M1-M6 和 FEATURE-002 成果的兼容性引用。"
    },
    "disclaimer": {
      "type": "string",
      "pattern": "不构成投资建议"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    }
  }
}
