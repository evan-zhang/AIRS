{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://airs.local/schemas/score/scorecard.schema.json",
  "title": "AIRS Scorecard",
  "description": "AIRS 综合评分卡 Schema。评分仅用于研究质量控制，不构成投资建议。",
  "type": "object",
  "required": [
    "scorecard_id",
    "version",
    "artifact_type",
    "methodology_refs",
    "evidence_chain_refs",
    "scores",
    "overall_score",
    "overall_grade",
    "confidence_score",
    "quality_gate",
    "disclaimer"
  ],
  "properties": {
    "scorecard_id": {
      "type": "string",
      "pattern": "^SCORECARD-[A-Za-z0-9_-]+$"
    },
    "version": {
      "type": "string"
    },
    "artifact_type": {
      "type": "string",
      "enum": ["prompt_output", "skill_output", "report", "benchmark_case", "research_run"]
    },
    "methodology_refs": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "evidence_chain_refs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "scores": {
      "type": "array",
      "items": { "$ref": "score.schema.json" },
      "minItems": 1
    },
    "overall_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "overall_grade": {
      "type": "string",
      "enum": ["A", "B", "C", "D", "E"]
    },
    "confidence_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "quality_gate": {
      "type": "string",
      "enum": ["PASS", "CONDITIONAL_PASS", "FAIL"]
    },
    "weight_audit": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["dimension", "before", "after", "reason"],
        "properties": {
          "dimension": { "type": "string" },
          "before": { "type": "number" },
          "after": { "type": "number" },
          "reason": { "type": "string" }
        }
      }
    },
    "disclaimer": {
      "type": "string",
      "const": "仅供研究参考，不构成投资建议"
    }
  },
  "additionalProperties": false
}
