{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Autonomous Learning Engine Feature Schema",
  "description": "建立 AIRS Autonomous Learning Engine，从历史研究、Committee、Memory、Report 与 Outcome 中提取反馈、挖掘模式、生成规则并提出 Prompt、Methodology、Skill 与 Score 优化建议。。本 Schema 仅用于 AIRS 工程开发与研究质量控制，不构成投资建议。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "feature_id",
    "feature_name",
    "inputs",
    "outputs",
    "disclaimer"
  ],
  "properties": {
    "feature_id": {
      "type": "string",
      "const": "FEATURE-012"
    },
    "feature_name": {
      "type": "string",
      "const": "Autonomous Learning Engine"
    },
    "inputs": {
      "type": "object",
      "description": "Feature 输入。"
    },
    "outputs": {
      "type": "object",
      "description": "Feature 输出。"
    },
    "risk_level": {
      "type": "string",
      "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"],
      "default": "HIGH"
    },
    "disclaimer": {
      "type": "string",
      "description": "本生成物仅用于 AIRS 工程开发与研究质量控制，不构成投资建议，不提供荐股、自动交易、交易指令、目标价或收益承诺。"
    }
  }
}
