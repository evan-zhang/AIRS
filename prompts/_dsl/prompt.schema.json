{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://airs.local/schemas/prompt-dsl.schema.json",
  "title": "AIRS Prompt DSL Schema",
  "type": "object",
  "required": ["metadata", "methodology_refs", "evidence_refs", "sections", "compliance"],
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["prompt_id", "name", "version", "category", "status"],
      "properties": {
        "prompt_id": {"type": "string", "minLength": 3},
        "name": {"type": "string", "minLength": 3},
        "version": {"type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$"},
        "category": {"type": "string"},
        "status": {"type": "string", "enum": ["DRAFT", "IN_REVIEW", "APPROVED", "APPROVED_WITH_LIMITATION", "NEEDS_REVISION", "DEPRECATED", "REJECTED"]}
      }
    },
    "methodology_refs": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "pattern": "^docs/methodology/.+\\.md$"}
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "pattern": "^docs/evidence/.+\\.md$"}
    },
    "sections": {
      "type": "array",
      "minItems": 7,
      "items": {"type": "string"}
    },
    "input_variables": {
      "type": "array",
      "items": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"}
    },
    "compliance": {
      "type": "object",
      "required": ["disclaimer_required", "forbidden_outputs"],
      "properties": {
        "disclaimer_required": {"type": "boolean", "const": true},
        "forbidden_outputs": {"type": "array", "items": {"type": "string"}}
      }
    }
  }
}

